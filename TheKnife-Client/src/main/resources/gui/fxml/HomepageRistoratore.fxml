<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="a_a.theknife.client.controller.HomepageRistoratoreController">
   
   <!-- Navbar Superiore (Allineata graficamente a HomeGuest.fxml) -->
   <top>
      <HBox prefHeight="80.0" style="-fx-background-color: #007161;" BorderPane.alignment="CENTER">
         <children>
            <!-- Logo Testuale -->
            <Label text="The Knife" textFill="WHITE">
               <font>
                  <Font name="Georgia Bold" size="36.0" />
               </font>
               <HBox.margin>
                  <Insets left="40.0" top="18.0" />
               </HBox.margin>
            </Label>
            
            <!-- Sottotitolo Modalità -->
            <Label text=" - modalità ristoratore" textFill="#b2dfdb">
               <font>
                  <Font name="Georgia" size="20.0" />
               </font>
               <HBox.margin>
                  <Insets top="28.0" />
               </HBox.margin>
            </Label>
            
            <!-- Region per spingere gli elementi a destra -->
            <Region prefHeight="80.0" HBox.hgrow="ALWAYS" />
            
            <!-- Area Profilo: Benvenuto e Bottoni -->
            <HBox alignment="CENTER_RIGHT" spacing="20.0">
               <HBox.margin>
                  <Insets bottom="18.0" right="40.0" top="18.0" />
               </HBox.margin>
               <children>
                  <Label fx:id="lblBenvenuto" text="Bentornato!" textFill="#b2dfdb">
                     <font>
                        <Font name="Georgia" size="18.0" />
                     </font>
                  </Label>
                  
                  <Button fx:id="btnProfilo" mnemonicParsing="false" onAction="#vaiAGestisciProfilo" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-cursor: hand;" text="Il mio profilo">
                     <font>
                        <Font size="14.0" />
                     </font>
                     <padding>
                        <Insets left="15.0" right="15.0" />
                     </padding>
                  </Button>
                  
                  <Button fx:id="btnLogout" mnemonicParsing="false" onAction="#eseguiLogout" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-cursor: hand;" text="Logout">
                     <font>
                        <Font size="14.0" />
                     </font>
                     <padding>
                        <Insets left="15.0" right="15.0" />
                     </padding>
                  </Button>
               </children>
            </HBox>
         </children>
      </HBox>
   </top>
   
   <!-- Area Centrale: Split Screen dinamico e responsivo -->
   <center>
      <HBox BorderPane.alignment="CENTER">
         <children>
            
            <!-- Metà Sinistra (Sfondo Bianco) -->
            <StackPane style="-fx-background-color: #ffffff;" HBox.hgrow="ALWAYS">
               <children>
                  <!-- Card Gestione Ristoranti -->
                  <VBox fx:id="cardGestisci" alignment="CENTER" maxHeight="450.0" maxWidth="600.0" spacing="40.0" style="-fx-background-color: #007161; -fx-background-radius: 30;">
                     <effect>
                        <DropShadow blurType="GAUSSIAN" height="30.0" radius="14.5" width="30.0">
                           <color>
                              <Color opacity="0.4" />
                           </color>
                        </DropShadow>
                     </effect>
                     <children>
                        <Label text="Gestione Ristoranti" textFill="WHITE">
                           <font>
                              <Font name="Georgia Bold" size="36.0" />
                           </font>
                        </Label>
                        <Label alignment="CENTER" prefWidth="480.0" text="Visualizza un resoconto dei tuoi ristoranti, scopri le opinioni dei tuoi clienti e interagisci lasciando una risposta alle loro recensioni." textAlignment="CENTER" textFill="WHITE" wrapText="true">
                           <font>
                              <Font name="Georgia" size="18.0" />
                           </font>
                        </Label>
                        <Button fx:id="btnGestisciRistoranti" mnemonicParsing="false" onAction="#vaiAGestisciRistoranti" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: #ffffff; -fx-background-radius: 25;" text="I miei ristoranti" textFill="#007161">
                           <font>
                              <Font name="Georgia Bold" size="18.0" />
                           </font>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </StackPane>
            
            <!-- Metà Destra (Sfondo Verde) -->
            <StackPane style="-fx-background-color: #007161;" HBox.hgrow="ALWAYS">
               <children>
                  <!-- Card Nuovo Ristorante -->
                  <VBox fx:id="cardNuovo" alignment="CENTER" maxHeight="450.0" maxWidth="600.0" spacing="40.0" style="-fx-background-color: #ffffff; -fx-background-radius: 30;">
                     <effect>
                        <DropShadow blurType="GAUSSIAN" height="30.0" radius="14.5" width="30.0">
                           <color>
                              <Color opacity="0.4" />
                           </color>
                        </DropShadow>
                     </effect>
                     <children>
                        <Label text="Nuovo Ristorante" textFill="#007161">
                           <font>
                              <Font name="Georgia Bold" size="36.0" />
                           </font>
                        </Label>
                        <Label alignment="CENTER" prefWidth="480.0" text="Fai conoscere al pubblico la tua nuova attività! Specifica tutte le sue caratteristiche, i tipi di cucina proposti e i servizi offerti." textAlignment="CENTER" textFill="#007161" wrapText="true">
                           <font>
                              <Font name="Georgia" size="18.0" />
                           </font>
                        </Label>
                        <Button fx:id="btnNuovoRistorante" mnemonicParsing="false" onAction="#vaiARegistraRistorante" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: #007161; -fx-background-radius: 25;" text="Apri nuovo ristorante" textFill="WHITE">
                           <font>
                              <Font name="Georgia Bold" size="18.0" />
                           </font>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </StackPane>
            
         </children>
      </HBox>
   </center>
</BorderPane>
