<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="150.0" prefWidth="240.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="a_a.theknife.client.controller.CambioUsernameController">
   <children>
      <VBox prefHeight="150.0" prefWidth="240.0" spacing="15.0">
         <children>
            <TextField fx:id="nuovoUsername" promptText="Nuovo username:*" />
            <PasswordField fx:id="password" promptText="Inserire la password:*" />
            <Button fx:id="btnCambiaUsername" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#cambiaUsername" prefHeight="26.0" prefWidth="252.0" style="-fx-background-color: #007161;" text="Cambia Username" textFill="WHITE">
               <font>
                  <Font name="Georgia" size="14.0" />
               </font>
            </Button>
            <Button fx:id="btnAnnulla" mnemonicParsing="false" onAction="#annulla" prefHeight="26.0" prefWidth="250.0" style="-fx-background-color: #ff000f;" text="Annulla" textFill="WHITE">
               <font>
                  <Font name="Georgia" size="13.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </children>
</AnchorPane>
