<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="540.0" minWidth="960.0" prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="a_a.theknife.client.controller.GestioneRistorantiController">
   
   <!-- Navbar Superiore -->
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: #007161;" BorderPane.alignment="CENTER">
         <children>
            <!-- Logo Testuale -->
            <Label text="The Knife" textFill="WHITE">
               <font>
                  <Font name="Georgia Bold" size="36.0" />
               </font>
               <HBox.margin>
                  <Insets left="40.0" />
               </HBox.margin>
            </Label>
            
            <!-- Sottotitolo Modalità -->
            <Label text=" - gestione ristoranti" textFill="#b2dfdb">
               <font>
                  <Font name="Georgia" size="20.0" />
               </font>
               <HBox.margin>
                  <Insets bottom="5.0" top="10.0" />
               </HBox.margin>
            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <!-- Bottone Indietro -->
            <Button fx:id="tornaAHome" mnemonicParsing="false" onAction="#tornaHome" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-cursor: hand;" text="Torna indietro">
               <font>
                  <Font size="14.0" />
               </font>
               <padding>
                  <Insets left="15.0" right="15.0" />
               </padding>
               <HBox.margin>
                  <Insets right="40.0" />
               </HBox.margin>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </Button>
         </children>
      </HBox>
   </top>
   
   <!-- Corpo Centrale -->
   <center>
      <HBox spacing="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>
         <children>
            
            <!-- Colonna Sinistra: Lista Ristoranti (35%) -->
            <VBox prefWidth="400.0" HBox.hgrow="SOMETIMES">
               <children>
                  <Label text="I Tuoi Locali" textFill="#007161">
                     <font>
                        <Font name="Georgia Bold" size="24.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="15.0" />
                     </VBox.margin>
                  </Label>
                  <ScrollPane fx:id="scrollLista" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #ffffff; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="listaRistoranti" spacing="10.0">
                           <padding>
                              <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                           </padding>
                        </VBox>
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
            
            <!-- Colonna Destra: Dettagli Ristorante (65%) -->
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Dettagli e Recensioni" textFill="#007161">
                     <font>
                        <Font name="Georgia Bold" size="24.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="15.0" />
                     </VBox.margin>
                  </Label>
                  <ScrollPane fx:id="infoScroll" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #ffffff; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="infoRistorante" spacing="15.0">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                        </VBox>
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
            
         </children>
      </HBox>
   </center>
</BorderPane>
